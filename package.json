{
  "name": "doaas",
  "version": "1.4.1",
  "description": "DevOps-as-a-Service Cloudflare Worker",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler versions upload --env=production",
    "generate": "node scripts/generate-endpoints.mjs && node scripts/generate-version.mjs",
    "validate": "node scripts/validate.mjs",
    "build": "npm run generate && tsc",
    "test": "npm run build && node tests/worker.test.mjs",
    "test:e2e": "npm run build && node tests/e2e.mjs",
    "test:stress": "node tests/stress.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "lint:md": "npx markdownlint-cli \"**/*.md\"",
    "lint:md:fix": "npx markdownlint-cli \"**/*.md\" --fix",
    "audit": "npm audit"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "overrides": {
    "minimatch": ">=10.2.4",
    "undici": ">=7.28.0",
    "ws": ">=8.21.0",
    "linkify-it": ">=5.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260302.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.49.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.2",
    "wrangler": "^4.78.0"
  },
  "lint-staged": {
    "*.{ts,mjs,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yml,yaml}": "prettier --write",
    "*.md": [
      "prettier --write",
      "npx markdownlint-cli --fix"
    ]
  }
}
